# Environment Configuration for JSTC API
# Copy this file to .env and update the values as needed
# 
# Dynaconf automatically loads these environment variables
# Prefix with JSTC_ to override config values

# Environment selection (development, staging, production)
ENV_FOR_DYNACONF=development

# Security (REQUIRED - change in production)
JSTC_SECRET_KEY=your-secret-key-change-this-in-production

# Database override (optional - overrides config.yaml)
# JSTC_DATABASE__URL=postgresql://user:password@localhost/dbname
# JSTC_DATABASE__URL=sqlite:///./sql_app.db

# API overrides (optional)
# JSTC_API__HOST=0.0.0.0
# JSTC_API__PORT=8000
# JSTC_API__DEBUG=true

# CORS overrides (optional)
# JSTC_CORS__ALLOW_ORIGINS=["http://localhost:3000"]

# Feature flags override (optional)
# JSTC_FEATURES__ENABLE_RATE_LIMITING=true
# JSTC_FEATURES__ENABLE_METRICS=true

# External Services
# JSTC_REDIS_URL=redis://localhost:6379/0

# API Keys and External Service Credentials
# JSTC_STRIPE_SECRET_KEY=sk_test_...
# JSTC_SENDGRID_API_KEY=SG...
# JSTC_AWS_ACCESS_KEY_ID=...
# JSTC_AWS_SECRET_ACCESS_KEY=...
